###############################################################################
# General
###############################################################################
ENVIRONMENT=dev
LOG_LEVEL=INFO
RANDOM_SEED=42
USE_GPU=false

###############################################################################
# Paths
###############################################################################
DATA_DIR=./data
RAW_DIR=./data/raw
PROCESSED_DIR=./data/processed
SQLITE_DIR=./data/sqlite

ARTIFACTS_DIR=./artifacts
ARTIFACTS_MODELS_DIR=./artifacts/models
ARTIFACTS_EMBEDDINGS_DIR=./artifacts/embeddings
ARTIFACTS_VECTOR_STORE_DIR=./artifacts/vector_store
ARTIFACTS_REPORTS_DIR=./artifacts/reports
ARTIFACTS_EVALUATIONS_DIR=./artifacts/evaluations

LOGS_DIR=./logs

###############################################################################
# Vector Store
###############################################################################
VECTOR_STORE_BACKEND=faiss
VECTOR_INDEX_NAME=default
VECTOR_STORE_DIR=./artifacts/vector_store

###############################################################################
# LLM - Routing
###############################################################################
CHAT_MODE=auto
API_PROVIDER=openai
HTTP_TIMEOUT_SEC=60

###############################################################################
# Local LLM (GGUF - llama-cpp-python)
###############################################################################
LOCAL_MODEL_PATH=<YOUR_KEY_HERE*>
HF_MODEL_ID=<YOUR_KEY_HERE*>
HF_MODEL_FILENAME=<YOUR_KEY_HERE*>
LOCAL_CTX_SIZE=4096
LOCAL_N_THREADS=4
LOCAL_N_GPU_LAYERS=0

###############################################################################
# vLLM (server mode - GPU only)
###############################################################################
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL=<YOUR_KEY_HERE*>
VLLM_API_KEY=<YOUR_KEY_HERE*>

###############################################################################
# OpenAI
###############################################################################
OPENAI_API_KEY=<YOUR_KEY_HERE*>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

###############################################################################
# xAI
###############################################################################
XAI_API_KEY=<YOUR_KEY_HERE*>
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-2-latest
XAI_EMBEDDING_MODEL=grok-embedding

###############################################################################
# Gemini
###############################################################################
GEMINI_API_KEY=<YOUR_KEY_HERE*>
GOOGLE_GENERATIVE_AI_API_KEY=<YOUR_KEY_HERE*>
GOOGLE_API_KEY=<YOUR_KEY_HERE*>
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

###############################################################################
# Generic OpenAI-Compatible Provider
###############################################################################
GENERIC_OAI_API_KEY=<YOUR_KEY_HERE*>
GENERIC_OAI_BASE_URL=<YOUR_KEY_HERE*>
GENERIC_OAI_MODEL=<YOUR_KEY_HERE*>
GENERIC_OAI_EMBEDDING_MODEL=<YOUR_KEY_HERE*>

###############################################################################
# Local Embeddings (SentenceTransformers)
###############################################################################
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

###############################################################################
# Autonomous Loop
###############################################################################
MAX_EXECUTION_STEPS=5
MAX_TOOL_CALLS=10
ENABLE_SELF_CORRECTION=true

###############################################################################
# Monitoring & Evaluation
###############################################################################
ENABLE_PROMETHEUS=true
ENABLE_LLM_JUDGE=false
EVALUATION_EXPORT_JSON=true

###############################################################################
# API Server
###############################################################################
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

###############################################################################
# Security
###############################################################################
X_API_KEY=<YOUR_KEY_HERE*>