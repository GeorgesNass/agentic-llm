## ============================================
## General
## ============================================
ENVIRONMENT=dev
LOG_LEVEL=INFO

## ============================================
## Paths
## ============================================
DATA_DIR=./data
RAW_DIR=./data/raw
INTERIM_DIR=./data/interim
PROCESSED_DIR=./data/processed

ARTIFACTS_DIR=./artifacts
LOGS_DIR=./logs
SECRETS_DIR=./secrets

## ============================================
## ANOMALY DETECTION
## ============================================
ANOMALY_DETECTION_ENABLED=true
ANOMALY_METHOD=zscore
Z_THRESHOLD=3.0
IQR_MULTIPLIER=1.5
ANOMALY_STRICT_MODE=false

## ============================================
## API
## ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

## ============================================
## LLM Providers Security
## ============================================
LLM_SECRETS_FILE=secrets/llm_secrets.json 			## X_API_KEY, OPENAI_API_KEY, GOOGLE_API_KEY, XAI_API_KEY

## ============================================
## LLM Providers - OpenAI
## ============================================
OPENAI_BASE_URL=https://api.openai.com/v1

## ============================================
## LLM Providers - Google Gemini
## ============================================
GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

## ============================================
## LLM Providers - xAI (Grok)
## ============================================
XAI_BASE_URL=https://api.x.ai/v1

## ============================================
## Default models (optional)
## ============================================
DEFAULT_CHAT_PROVIDER=openai
DEFAULT_CHAT_MODEL=gpt-4o-mini
DEFAULT_EMBEDDINGS_PROVIDER=openai
DEFAULT_EMBEDDINGS_MODEL=text-embedding-3-small

## ============================================
## Cost simulation defaults (optional)
## ============================================
COST_DEFAULT_EXPECTED_OUTPUT_TOKENS=1024
COST_DEFAULT_MAX_CHARS_PER_FILE=200000
COST_DEFAULT_RECURSIVE=true
COST_DEFAULT_CHUNK_SIZE=2000
COST_DEFAULT_CHUNK_OVERLAP=200