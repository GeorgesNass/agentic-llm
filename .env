## ============================================
## Project settings
## ============================================
PROJECT_NAME=local-quantization
ENV=dev
PROFILE=gpu

## ============================================
## Pipeline settings
## ============================================
PIPELINE_MODE=full							 			## quantize | export | benchmark | full

## ============================================
## Model settings
## ============================================
MODEL_NAME_OR_PATH=mistralai/Mistral-7B-Instruct-v0.3
MODEL_REVISION=<YOUR_HF_MODEL_REVISION>                 ## Optional HF revision or branch
ADAPTER_PATH=<YOUR_OPTIONAL_ADAPTER_PATH>

## ============================================
## Quantization settings (COMMON)
## ============================================
QUANT_BACKEND=awq 										## gguf | awq | gptq | bnb_nf4 | onnx
QUANT_BITS=4 											## Target bit-width (backend dependent)
QUANT_GROUP_SIZE=128 									## Optional group size (GPTQ / AWQ)
CALIBRATION_DATASET=./data/calibration.txt              ## Calibration dataset (optional but recommended for awq/gptq/onnx)

## ============================================
## Export settings
## ============================================
EXPORT_OUTPUT_DIR=./artifacts/exports
EXPORT_OVERWRITE=false

## ============================================
## Benchmark settings
## ============================================
BENCHMARK_PROMPTS=./data/bench_prompts.txt
BENCHMARK_MAX_TOKENS=256
BENCHMARK_RUNS=5

## ============================================
## Logging settings
## ============================================
LOCAL_QUANTIZATION_LOG_LEVEL=INFO
LOCAL_QUANTIZATION_LOG_TO_FILE=true
LOCAL_QUANTIZATION_LOG_MAX_BYTES=10485760
LOCAL_QUANTIZATION_LOG_BACKUP_COUNT=5

## ============================================
## Security
## ============================================
APP_SECRETS_FILE=secrets/app_secrets.json                ## API KEY & HUGGING FACE KEY 