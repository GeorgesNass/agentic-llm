## ============================================================
## Application
## ============================================================
ENVIRONMENT=dev
APP_VERSION=1.0.0
LOG_LEVEL=INFO

## ============================================================
## OCR configuration
## ============================================================
OCR_MODE=local_docker
OCR_DOCKER_IMAGE=georgesnass/ocr-universal:latest
OCR_SERVICE_URL=http://ocr-service:8000

## ============================================================
## ANOMALY DETECTION
## ============================================================
ANOMALY_DETECTION_ENABLED=true
ANOMALY_METHOD=zscore
Z_THRESHOLD=3.0
IQR_MULTIPLIER=1.5
ANOMALY_STRICT_MODE=false

## ============================================================
## GCP Service Account
## ============================================================
GCP_CONFIG_FILE=secrets/gcp_config.json 								## Google Drive ID, Project Id & Region, GCS bucket texts & emebeddings
GOOGLE_APPLICATION_CREDENTIALS_FILE=secrets/gcp_service_account.json

## ============================================================
## Vertex AI
## ============================================================
VERTEX_LLM_MODEL=text-bison@001
VERTEX_EMBED_MODEL=textembedding-gecko@001

## ============================================================
## Google Cloud Storage
## ============================================================
GCS_PREFIX_TEXT=texts/
GCS_PREFIX_EMB=embeddings/

## ============================================================
## RAG parameters
## ============================================================
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
TOP_K=8

## ============================================================
## Local files handling
## ============================================================
KEEP_LOCAL=false
